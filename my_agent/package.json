{
  "name": "my-agent",
  "version": "0.1.0",
  "description": "AI Agent CLI Tool - A Claude Code inspired agent",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --outdir=dist --target=bun",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@types/uuid": "^11.0.0",
    "glob": "^10.3.0",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
